{
  "name": "opencode-account-rotator",
  "version": "0.1.0",
  "description": "OpenCode plugin that adds round-robin account rotation with cooldown tracking and TUI sidebar on top of anthropic-login-via-cli",
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"No tests yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "account-rotation",
    "claude",
    "anthropic"
  ],
  "author": "Gianpierre Mio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DarkCodex29/opencode-account-rotator"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opentui/solid": "*",
    "@types/node": "^22.0.0",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.12",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    },
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "opencode": "^1.0.0"
  }
}
